    RowBox[{"Run", " ", "a", " ", "normal", " ", "query"}], "\[LongDash]", 
    RowBox[{"comes", " ", "back", " ", "as", " ", "a", " ", "Tabular"}]}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"libs", "[", "\"\<duckdb::db_query\>\"", "]"}], "[", 
