Cell[BoxData[{
 RowBox[{
  RowBox[{"repo", " ", "=", " ", 
   RowBox[{"ExpandFileName", "[", 
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"NotebookDirectory", "[", "]"}], ",", " ", "\"\<..\>\""}], 
      "}"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"out", " ", "=", " ", 
   RowBox[{"NotebookDirectory", "[", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cargo", " ", "=", " ", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
     "$HomeDirectory", ",", " ", "\"\<.cargo\>\"", ",", " ", "\"\<bin\>\"", ",",
       " ", "\"\<cargo\>\""}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"env", " ", "=", " ", 
    RowBox[{"<|", 
     RowBox[{"\"\<PATH\>\"", " ", "->", 
      " ", "\"\</opt/homebrew/bin:/opt/homebrew/sbin:/usr/bin:/bin:/usr/sbin:/\
sbin\>\""}], "|>"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"SetEnvironment", "[", 
    RowBox[{"\"\<LIBRARY_LINK_RUST_BACKTRACE\>\"", " ", "->", 
     " ", "\"\<True\>\""}], "]"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"add", " ", "rust", " ", "panic", " ", "backtraces"}], " ", 
   "*)"}]}]}], "Code",
