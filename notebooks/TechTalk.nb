        RowBox[{"\"\<ProcessEnvironment\>\"", " ", "->", " ", "env"}], ",", 
        "\n", "       ", 
        RowBox[{"\"\<ReturnType\>\"", " ", "->", 
         " ", "\"\<StandardOutput\>\""}]}], "\n", "  ", "}"}], ",", "\n", 
      "  ", "commands"}], "\n", "]"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
