    RowBox[{"no", " ", "such", " ", "table"}], ",", 
    RowBox[{"so", " ", "this", " ", "returns", " ", 
     RowBox[{"Failure", "[", 
      RowBox[{"\"\<QueryError\>\"", ",", "..."}], "]"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"libs", "[", "\"\<duckdb::db_query\>\"", "]"}], "[", 
